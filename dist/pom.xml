<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <artifactId>dongting</artifactId>
        <groupId>com.github.dtprj.dongting</groupId>
        <version>0.8-SNAPSHOT</version>
    </parent>
    <artifactId>dongting-dist</artifactId>
    <dependencies>
        <dependency>
            <groupId>com.github.dtprj.dongting</groupId>
            <artifactId>dongting-test-support</artifactId>
            <version>0.8-SNAPSHOT</version>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>com.github.dtprj.dongting</groupId>
            <artifactId>dongting-client</artifactId>
            <version>0.8-SNAPSHOT</version>
        </dependency>
        <dependency>
            <groupId>com.github.dtprj.dongting</groupId>
            <artifactId>dongting-server</artifactId>
            <version>0.8-SNAPSHOT</version>
        </dependency>
    </dependencies>
    <properties>
        <dist.basename>dongting-dist</dist.basename>
        <dist.descriptor>src/assembly/assembly.xml</dist.descriptor>
    </properties>
    <build>
        <finalName>dongting-dist-${project.version}</finalName>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <configuration>
                    <source>11</source>
                    <target>11</target>
                    <release>11</release>
                </configuration>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-assembly-plugin</artifactId>
                <version>3.8.0</version>
                <executions>
                    <execution>
                        <id>make-assembly</id>
                        <phase>package</phase>
                        <goals>
                            <goal>single</goal>
                        </goals>
                        <configuration>
                            <descriptors>
                                <descriptor>${dist.descriptor}</descriptor>
                            </descriptors>
                            <finalName>dongting-dist</finalName>
                            <appendAssemblyId>false</appendAssemblyId>
                            <outputDirectory>${project.basedir}/../target</outputDirectory>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-antrun-plugin</artifactId>
                <version>3.2.0</version>
                <executions>
                    <execution>
                        <id>create-dist-zip</id>
                        <phase>package</phase>
                        <goals>
                            <goal>run</goal>
                        </goals>
                        <configuration>
                            <target>
                                <zip destfile="${project.basedir}/../target/${dist.basename}.zip">
                                    <zipfileset dir="${project.basedir}/../target/dongting-dist" prefix="${dist.basename}"/>
                                </zip>
                            </target>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>
    <profiles>
        <profile>
            <id>addJRE</id>
            <build>
                <plugins>
                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-antrun-plugin</artifactId>
                        <version>3.2.0</version>
                        <executions>
                            <execution>
                                <id>create-dist-zip</id>
                                <phase>none</phase>
                            </execution>
                        </executions>
                    </plugin>
                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-antrun-plugin</artifactId>
                        <version>3.2.0</version>
                        <executions>
                            <execution>
                                <id>run-jlink-cut</id>
                                <phase>package</phase>
                                <goals>
                                    <goal>run</goal>
                                </goals>
                                <configuration>
                                    <target>
                                        <echo message="Running jlink-cut for trimmed JRE..."/>
                                        <exec executable="./jlink-cut.sh"
                                              dir="${project.basedir}/../target/dongting-dist/bin"
                                              osfamily="unix"
                                              failonerror="true"/>
                                        <exec executable="cmd"
                                              dir="${project.basedir}/../target/dongting-dist/bin"
                                              osfamily="windows"
                                              failonerror="true">
                                            <arg value="/c"/>
                                            <arg value="jlink-cut.bat"/>
                                        </exec>
                                        <echo message="Packaging dongting-dist.zip with trimmed JRE..."/>
                                        <zip destfile="${project.basedir}/../target/${dist.basename}.zip">
                                            <zipfileset dir="${project.basedir}/../target/dongting-dist" prefix="${dist.basename}"/>
                                        </zip>
                                    </target>
                                </configuration>
                            </execution>
                        </executions>
                    </plugin>
                </plugins>
            </build>
        </profile>
        <profile>
            <id>minimalDist</id>
            <properties>
                <dist.descriptor>src/assembly/assembly-minimal.xml</dist.descriptor>
            </properties>
        </profile>
    </profiles>
</project>
